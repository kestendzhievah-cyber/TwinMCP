# =============================================================================
# Firebase Client-Side Configuration (REQUIRED for Google/GitHub OAuth)
# =============================================================================
# Get these values from: Firebase Console > Project Settings > General > Your apps > Web app
#
# 1. Go to https://console.firebase.google.com
# 2. Select your project (studio-3830496577-209fb)
# 3. Click the gear icon > Project Settings
# 4. Scroll down to "Your apps" > Web app (or create one)
# 5. Copy the config values below
#
# IMPORTANT: Also enable Google and GitHub sign-in providers:
# Firebase Console > Authentication > Sign-in method > Add provider
# For GitHub: you also need to create an OAuth App at https://github.com/settings/developers
#   - Set the callback URL to: https://<YOUR_PROJECT_ID>.firebaseapp.com/__/auth/handler
# =============================================================================

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=studio-3830496577-209fb.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=studio-3830496577-209fb
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=studio-3830496577-209fb.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# =============================================================================
# Firebase Server-Side (Admin SDK) — for backend token verification
# =============================================================================
FIREBASE_PROJECT_ID=studio-3830496577-209fb
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@studio-3830496577-209fb.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...your-private-key...\n-----END PRIVATE KEY-----\n"

# =============================================================================
# Database (REQUIRED)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/twinmcp

# =============================================================================
# JWT Secret (REQUIRED)
# =============================================================================
JWT_SECRET=dev-secret-key-at-least-32-characters-long

# =============================================================================
# Optional
# =============================================================================
# REDIS_URL=redis://localhost:6379
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GITHUB_TOKEN=ghp_...
# STRIPE_SECRET_KEY=sk_test_...
