# ---------------------------------------------------------------------------
# TwinMCP environment variables
# Copy to .env.local (for apps/backend) or set in Vercel / Railway dashboards.
# See PROVISIONING.md for how to obtain each value.
# ---------------------------------------------------------------------------

# --- Public URLs -----------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://twinmcp.com
TWINMCP_API_URL=https://twinmcp.com/api
RESOURCE_URL=https://mcp.twinmcp.com
AUTH_SERVER_URL=https://twinmcp.com

# --- Postgres (Supabase) ---------------------------------------------------
# Transaction pooler (port 6543, PgBouncer) — runtime / serverless
DATABASE_URL=postgres://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1
# Direct connection (port 5432) — migrations only
DATABASE_URL_UNPOOLED=postgres://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# Optional — only if you use Supabase Storage or RLS from the client
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Redis (Upstash) -------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# --- Object storage (Cloudflare R2 or S3) ----------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=twinmcp-docs
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# --- Auth (Supabase Auth — included with your Supabase project) ------------
# Already set via NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY above.
# No extra config needed — Supabase Auth runs on the same project.

# --- OAuth 2.1 (for MCP HTTP transport) ------------------------------------
OAUTH_ISSUER=https://twinmcp.com
OAUTH_JWT_PRIVATE_KEY=
OAUTH_JWT_PUBLIC_KEY=

# --- Billing (Stripe) ------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...

# --- AI (OpenAI) -----------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Ingestion worker (apps/ingest) ---------------------------------------
# Personal access token with `public_repo` scope (bumps rate limit 60→5000/h)
GITHUB_TOKEN=
# Full redis:// URL for BullMQ (distinct from the Upstash REST pair above).
# Upstash exposes both — use the "Redis Connect" TCP URL here.
REDIS_URL=
INGEST_CONCURRENCY=2

# --- Email (Resend) --------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@twinmcp.com

# --- Observability ---------------------------------------------------------
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=twinmcp

# --- Security --------------------------------------------------------------
# 64 hex chars (32 bytes), generate with: openssl rand -hex 32
CLIENT_IP_ENCRYPTION_KEY=

# --- Rate limits (defaults if unset) --------------------------------------
RATE_LIMIT_FREE_DAILY=50
RATE_LIMIT_PRO_DAILY=10000
